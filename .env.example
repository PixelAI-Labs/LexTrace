# LexTrace local environment
# Copy this file to .env and fill in real values.

GOOGLE__API_KEY=your-google-custom-search-api-key
GOOGLE__SEARCH_ENGINE_ID=your-google-search-engine-id

# Optional overrides
# DISCOVERY__MAX_QUERIES_PER_DISCOVERY=8
# DISCOVERY__DEFAULT_SEARCH_DEPTH=shallow
# APP__HOST=0.0.0.0
# APP__PORT=8000
# APP__DEBUG=false
# APP__RELOAD=false
